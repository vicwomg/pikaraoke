# auto-translated
#: routes/queue.py:151
msgid "Error moving to bottom of queue"
msgstr "Terjadi kesalahan saat berpindah ke antrean terbawah"

#: routes/queue.py:152
msgid "Error moving up in queue"
msgstr "Gagal memindahkan ke atas"

#: routes/queue.py:153
