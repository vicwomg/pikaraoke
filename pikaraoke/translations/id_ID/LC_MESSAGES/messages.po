msgstr "Dipindah ke posisi teratas antrian"

#: routes/queue.py:144
msgid "Moved to bottom of queue"
msgstr "Dipindah ke posisi terbawah antrian"

#: routes/queue.py:145
msgid "Moved up in queue"
msgstr "Naik satu posisi dalam antrian"

#: routes/queue.py:146
